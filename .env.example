# ProtonMail Bridge (localhost only)
PROTON_IMAP_HOST=127.0.0.1
PROTON_IMAP_PORT=1143
PROTON_SMTP_HOST=127.0.0.1
PROTON_SMTP_PORT=1025
PROTON_EMAIL=you@proton.me
PROTON_BRIDGE_PASSWORD=<bridge-generated password>

# Groq API
GROQ_API_KEY=<your key>
LLM_MODEL=openai/gpt-oss-120b

# Optional — persistent user context for folder recommendations
# USER_CONTEXT=software engineer, client work and open source projects

# Optional — ARQ task queue
# REDIS_URL=redis://localhost:6379
